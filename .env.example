# ActraDeck 環境変数テンプレート。
# 実値は .env にコピーして埋める。.env はコミットしない (.gitignore 済み)。
# 平文 secret をリポジトリに置かないこと (.claude/rules/security.md)。

# --- PostgreSQL (docker-compose) ---
POSTGRES_USER=actradeck
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=actradeck
# host 側公開ポート (他プロジェクトと衝突しない offset)。
ACTRADECK_PG_PORT=55432

# --- アプリ / マイグレーションが読む接続文字列 ---
# node-pg-migrate / pg はこの DATABASE_URL を参照する。
# 上の値と整合させること (port は ACTRADECK_PG_PORT)。
DATABASE_URL=postgresql://actradeck:change_me_local_only@localhost:55432/actradeck

# --- ポート割り当て (ActraDeck 55xxx ブロック / 他プロジェクトと衝突回避) ---
# ActraDeck uses the 554xx port range to avoid clashing with other local services.
# webui の既定 3000 は他プロセスと衝突するため必ず offset を使う。
ACTRADECK_WEBUI_PORT=55400
ACTRADECK_BACKEND_PORT=55410
ACTRADECK_BACKEND_HOST=127.0.0.1
# Sidecar の hook receiver は 127.0.0.1 の ephemeral port (固定ポート不要・衝突しない)。

# --- Ingestion 受信認証 (Phase 3 backend) ---
# sidecar → backend の WS/HTTP ingestion を認証するトークン。
# crypto.randomBytes(32).toString('hex') 等で生成し .env にのみ置く (コミットしない)。
# backend と sidecar で同一値を共有する。未設定だと backend は起動を拒否する (無認証受信を作らない)。
INGEST_TOKEN=replace_me_with_random_hex_32_bytes

# --- UI Realtime 認証 (Phase 3 ③) ---
# backend → UI の /realtime/ws を認証するトークン。INGEST_TOKEN とは **別経路・別認証**
# (sidecar token を UI に配らない)。Authorization: Bearer で渡す (?token= 不可)。
# crypto.randomBytes(32).toString('hex') 等で生成。未設定なら /realtime/ws は mount されない。
# webui の BFF custom server (apps/webui/server.ts) も **同じ REALTIME_TOKEN を server env から**
# 読み、backend へ Bearer 中継する (ADR 019e92b7)。**NEXT_PUBLIC_ にしない・ブラウザに渡さない**。
REALTIME_TOKEN=replace_me_with_another_random_hex_32_bytes

# --- WebUI BFF relay 先 (Phase 4) ---
# webui custom server がブラウザの same-origin /realtime/ws を中継する backend の WS endpoint。
# **ws:// または wss:// のみ許可** (http(s):// や不正値は起動時に拒否し Bearer を誤送しない)。
# クライアントは指定不可 (SSRF 防止のため env 由来のみ)。backend の実ポートは ACTRADECK_BACKEND_PORT
# (既定 55410) と整合させること。
BACKEND_REALTIME_WS_URL=ws://127.0.0.1:55410/realtime/ws

# --- (任意) Project scope: デモ/集中表示の絞り込み ---
# attach daemon は user-scope hook で同マシンの全 Claude Code / Codex セッションを観測するため、
# 既定では cockpit に他プロジェクトの作業 (cwd basename) も混ざる。concierge 等でライブ画面共有する
# 際に他プロジェクト名を露出させたくない場合、観測対象を cwd 前方一致 allowlist へ絞る。
# - カンマ区切りの cwd prefix。完全一致 + その配下のみ通す (兄弟ディレクトリは通さない)。
# - 設定すると Live Wall / Board / Approval Inbox / Audit の **一覧** が一致分のみになる (narrows only)。
# - **未設定 (既定) = 全件** (現行挙動)。デモ後は外す (or 空) ことで通常表示へ戻る。
# 例: 専用デモ repo だけを見せる → ACTRADECK_PROJECT_SCOPE=/tmp/ad-demo
# ACTRADECK_PROJECT_SCOPE=
