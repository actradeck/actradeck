{
  "$description": "Adaptive Clarity 2030 — Dark テーマ。semantic を dark 値で上書き（component は自動追従）。",
  "bg": {
    "canvas": { "$type": "color", "$value": "#16181d" },
    "surface": { "$type": "color", "$value": "#1e2127" },
    "layer": { "$type": "color", "$value": "#24272e" },
    "layer-raised": { "$type": "color", "$value": "#2a2e36" },
    "selected": { "$type": "color", "$value": "#16243f" }
  },
  "fg": {
    "primary": { "$type": "color", "$value": "#f3f4f6" },
    "muted": { "$type": "color", "$value": "#aab1bb" },
    "on-action": { "$type": "color", "$value": "#ffffff" }
  },
  "border": {
    "subtle": { "$type": "color", "$value": "#333842" },
    "strong": { "$type": "color", "$value": "#97a1ad" }
  },
  "focus": { "$type": "color", "$value": "#5b9bff" },
  "action": {
    "primary": {
      "bg": { "$type": "color", "$value": "#2563eb" },
      "bg-hover": { "$type": "color", "$value": "#1d4ed8" }
    },
    "danger": {
      "bg": { "$type": "color", "$value": "#c8332b" }
    }
  },
  "status": {
    "success": {
      "fg": { "$type": "color", "$value": "#5cd98a" },
      "bg": { "$type": "color", "$value": "#122a1c" }
    },
    "warn": {
      "fg": { "$type": "color", "$value": "#e8b94d" },
      "bg": { "$type": "color", "$value": "#2e2410" }
    },
    "danger": {
      "fg": { "$type": "color", "$value": "#ffb0a8" },
      "bg": { "$type": "color", "$value": "#2e1513" }
    },
    "info": {
      "fg": { "$type": "color", "$value": "#9bbcff" },
      "bg": { "$type": "color", "$value": "#14213e" }
    }
  }
}
