{"version": 2, "width": 80, "height": 24, "timestamp": 1782044681, "env": {"SHELL": "/bin/bash", "TERM": "tmux-256color"}}
[0.002839, "o", "\r\n\u001b[1;36m== ActraDeck — set up in one command ==\u001b[0m\r\n"]
[0.803731, "o", "\u001b[0;90mFresh clone -> running cockpit. (Node 20+, pnpm, Docker compose.)\u001b[0m\r\n"]
[1.204621, "o", "\r\n\u001b[1;36m== 1) prerequisites ==\u001b[0m\r\n"]
[2.005675, "o", "\u001b[1;32m$\u001b[0m node --version\r\n"]
[2.408799, "o", "v22.16.0\r\n"]
[3.21006, "o", "\u001b[1;32m$\u001b[0m pnpm --version\r\n"]
[3.835312, "o", "10.28.2\r\n"]
[4.64033, "o", "\u001b[1;32m$\u001b[0m docker compose version | head -1\r\n"]
[5.185318, "o", "Docker Compose version v2.35.1\r\n"]
[5.991122, "o", "\r\n\u001b[1;36m== 2) ./scripts/quickstart writes .env for you (random secrets, mode 0600) ==\u001b[0m\r\n"]
[6.803421, "o", "\u001b[1;32m$\u001b[0m grep -E '^(POSTGRES_PASSWORD|INGEST_TOKEN|REALTIME_TOKEN)=' .env\r\n"]
[7.605769, "o", "POSTGRES_PASSWORD=*****(generated, 0600)\r\nINGEST_TOKEN=*****(generated, 0600)\r\nREALTIME_TOKEN=*****(generated, 0600)\r\nINGEST_TOKEN=*****(generated, 0600)\r\nREALTIME_TOKEN=*****(generated, 0600)\r\n"]
[8.410813, "o", "\r\n\u001b[1;36m== 3) quickstart then starts Postgres, migrates, and brings up all tiers ==\u001b[0m\r\n"]
[9.211631, "o", "\u001b[1;32m$\u001b[0m docker compose up -d   #  Postgres :55432\r\n"]
[10.012446, "o", "\u001b[1;32m$\u001b[0m pnpm db:migrate        #  schema\r\n"]
[10.813481, "o", "\u001b[1;32m$\u001b[0m ./scripts/actradeck up #  backend :55410 + web UI :55400 + attach daemons\r\n"]
[11.61437, "o", "\r\n\u001b[1;36m== 4) confirm it is healthy (read-only) ==\u001b[0m\r\n"]
[12.41526, "o", "\u001b[1;32m$\u001b[0m ./scripts/actradeck doctor 2>&1 | sed -n '1,18p'\r\n"]
[12.819798, "o", "[doctor] repo: /home/user/Files/ActraDeck\r\n"]
[12.820074, "o", "[doctor] node: /home/user/.nvm/versions/node/v22.16.0/bin/node\r\n"]
[12.8201, "o", "[doctor] 注意: node が nvm パス。更新時は actradeck up を再実行 (203/EXEC 回避)。\r\n"]
[12.821327, "o", "[doctor] .env: present (perm=664)\r\n[doctor] 警告: .env が 664。`chmod 600 /home/user/Files/ActraDeck/.env` を推奨。\r\n"]
[12.822365, "o", "[doctor] .env: INGEST_TOKEN 設定あり (値は非表示)\r\n"]
[12.823112, "o", "[doctor] .env: REALTIME_TOKEN 設定あり (値は非表示)\r\n"]
[12.826503, "o", "[doctor] linger: yes\r\n"]
[12.831887, "o", "[doctor] actradeck-backend: active / enabled\r\n"]
[12.836455, "o", "[doctor] actradeck-webui: active / enabled\r\n"]
[12.844692, "o", "[doctor] actradeck-attach: active / enabled\r\n"]
[12.851511, "o", "[doctor] actradeck-codex-attach: active / enabled\r\n"]
[12.868363, "o", "[doctor] :55410 backend LISTEN ✓\r\n"]
[12.888074, "o", "[doctor] :55400 webui LISTEN ✓\r\n"]
[13.692157, "o", "\u001b[1;32m$\u001b[0m curl -s -o /dev/null -w 'cockpit http://localhost:55400 -> HTTP %{http_code}\\n' http://localhost:55400\r\n"]
[14.099913, "o", "cockpit http://localhost:55400 -> HTTP 200\r\n"]
[14.90126, "o", "\r\n\u001b[1;36m== Done — open http://localhost:55400, then run 'claude' or 'codex' ==\u001b[0m\r\n"]
